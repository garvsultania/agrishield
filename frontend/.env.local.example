# Copy to .env.local and override as needed.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Backend API base (the Express service in ../backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Deployed Soroban contract and the admin pubkey bound to every pool.
# Defaults in lib/env.ts point at the current testnet deployment; override here
# after rotating the contract.
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=CBQ3QTCA2552XXBVJCKVRWTRMNHMYAAJC6PR4N5IXIYNVJCQFPLD7XLX
NEXT_PUBLIC_ADMIN_PUBKEY=GDEF3Z6T3F5HY6IZ4W7MO4R7OSLPQVMPXVQKC55OVF73MJKBNHC7QUT2

# Shared-secret Bearer token for the simulate endpoint. Must match the
# backend's ADMIN_API_TOKEN. Leave blank in dev to call the endpoint without
# authentication.
#
# SECURITY NOTE: NEXT_PUBLIC_ leaks into the client bundle. Treat this as a
# deploy-time floor, not per-user auth. Combined with the backend's IP rate
# limit + CORS allowlist, it deters casual abuse.
NEXT_PUBLIC_API_TOKEN=
