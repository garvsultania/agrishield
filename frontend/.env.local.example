# Copy to .env.local and override as needed.
# These values are inlined at build time via Next's NEXT_PUBLIC_ convention.

# Backend API base (the Express service in ../backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Deployed Soroban contract and the admin pubkey bound to every pool.
# Defaults in lib/env.ts point at the current testnet deployment; override here
# after rotating the contract.
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=CBQ3QTCA2552XXBVJCKVRWTRMNHMYAAJC6PR4N5IXIYNVJCQFPLD7XLX
NEXT_PUBLIC_ADMIN_PUBKEY=GDEF3Z6T3F5HY6IZ4W7MO4R7OSLPQVMPXVQKC55OVF73MJKBNHC7QUT2
