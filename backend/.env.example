# AgriShield Backend Environment Variables
# Copy this file to .env and fill in your values

# Sentinel Hub API Key (optional — falls back to mock data if not set)
SENTINEL_HUB_API_KEY=

# Stellar Network Configuration
STELLAR_ADMIN_SECRET_KEY=
STELLAR_NETWORK=testnet

# Soroban Smart Contract (optional — uses XLM payment fallback if not set)
SOROBAN_CONTRACT_ID=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# MongoDB (optional — uses JSON files if not set)
MONGODB_URI=

# Server
PORT=3001
