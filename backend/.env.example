# AgriShield backend — copy to .env and override as needed.

# ── Stellar / Soroban ─────────────────────────────────────────────────────────
# If unset, the server auto-generates + friendbot-funds a testnet keypair on
# first run. Set this to the key that was used to init the pools so payouts
# actually land.
STELLAR_ADMIN_SECRET_KEY=

STELLAR_NETWORK=testnet
SOROBAN_CONTRACT_ID=CBQ3QTCA2552XXBVJCKVRWTRMNHMYAAJC6PR4N5IXIYNVJCQFPLD7XLX
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Auth (optional) ───────────────────────────────────────────────────────────
# If set, /api/farm/:farmId/simulate requires "Authorization: Bearer <token>".
# If unset, the simulate endpoint is open (dev mode — logs a warning on boot).
ADMIN_API_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of origins. In dev, localhost:3000 + localhost:3002
# are always permitted. Set this to your frontend's deployed URL in prod.
# Example: CORS_ORIGINS=https://dashboard.agrishield.example.com
CORS_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Optional: MongoDB ─────────────────────────────────────────────────────────
# Currently unused; backend reads/writes JSON files. Wiring exists for a
# future migration — safe to leave blank.
MONGODB_URI=
